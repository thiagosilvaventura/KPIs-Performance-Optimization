import pandas as pd
# Importing the tool you just created in the src folder
from src.performance_analyzer import PerformanceAnalyzer

# 1. Load your dataset (update the path to your real CSV file)
# df = pd.read_csv('data/performance_logs.csv')

# Mmock dataset for an immediate test run
data = {
    'requests': [100, 150, 200, 50, 300, 120, 180],
    'success': [98, 145, 190, 10, 295, 115, 175],
    'latency_ms': [20, 25, 22, 850, 21, 24, 23] # Note the high latency anomaly at index 3
}
df = pd.DataFrame(data)

# 2. Initialize the Performance Analyzer
analyzer = PerformanceAnalyzer(df)

# 3. Execute the analysis pipeL.
analyzer.clean_data()
analyzer.calculate_efficiency_kpis(input_col='requests', output_col='success')
analyzer.detect_performance_outliers(column='latency_ms', threshold=2.0)

# 4. Display the summary report
report = analyzer.generate_summary_report()

print("--- Performance Analysis Summary ---")
print(f"Total Records Processed: {report['total_records']}")
print(f"Mean System Efficiency:  {report['avg_efficiency']:.2f}%")
print(f"Anomalies/Outliers Found: {report['outlier_count']}")

# 5. Review identified outliers (Risk Management)
if report['outlier_count'] > 0:
    print("\n--- Outlier Details ---")
    print(analyzer.df[analyzer.df['is_outlier'] == True])
